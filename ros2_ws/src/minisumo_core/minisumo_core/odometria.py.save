import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist, Pose2D
from sensor_msgs.msg import Imu
import math
import time

class CalculadoraOdometria(Node):
    def __init__(self):
        super().__init__('odometria_node')
        
       
        self.sub_motor = self.create_subscription(Twist, '/motor/telemetry', self.motor_callback, 10)
        self.sub_imu = self.create_subscription(Imu, '/imu/data_filtered', self.imu_callback, 10)
        
        
        self.pub_odom = self.create_publisher(Pose2D, '/posicion_estimada', 10)
        
        
        self.x = 0.0
        self.y = 0.0
        self.theta = 0.0
        
        
        self.v = 0.0
        self.w = 0.0
        self.ultimo_tiempo = time.time()
        
        
        self.timer = self.create_timer(0.05, self.actualizar_posicion)
        self.get_logger().info('Nodo de Odometría iniciado. Calculando X, Y...')

    def motor_callback(self, msg)        self.v = msg.linear.y  

    def imu_callback(self, msg):
        self.w = msg.angular_velocity.z  

    def actualizar_posicion(self):
        tiempo_actual = time.time()
        dt = tiempo_actual - self.ultimo_tiempo
        self.ultimo_tiempo = tiempo_actual
        
        # Evitamos saltos raros de tiempo
        if 0 < dt < 1.0:
            # 1. Integrar el ángulo (giro)
            self.theta += self.w * dt
            
            # 2. Integrar la posición usando trigonometría
            self.x += self.v * math.cos(self.theta) * dt
            self.y += self.v * math.sin(self.theta) * dt
            
            # 3. Empacar y publicar para Totoro
            msg_pose = Pose2D()
            msg_pose.x = self.x
            msg_pose.y = self.y
            msg_pose.theta = self.theta
            self.pub_odom.publish(msg_pose)

def main(args=None):
    rclpy.init(args=args)
    nodo = CalculadoraOdometria()
    try:
        rclpy.spin(nodo)
    except KeyboardInterrupt:
        pass
    finally:
        nodo.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
